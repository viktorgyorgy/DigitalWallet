ENV_NAME=dev

# Postgres Config
POSTGRES_HOST=postgres
POSTGRES_USER=wallet_admin
POSTGRES_PASSWORD=secure_wallet_pass
POSTGRES_DB=wallet_db
ConnectionStrings__PostgresConnection="Host=${POSTGRES_HOST};Port=5432;Database=${POSTGRES_DB};Username=${POSTGRES_USER};Password=${POSTGRES_PASSWORD}"

# Mongo Config
MONGO_HOST=mongo
MONGO_USER=mongo_admin
MONGO_PASSWORD=mongo_pass
ConnectionStrings__MongoConnection="mongodb://${MONGO_USER}:${MONGO_PASSWORD}@${MONGO_HOST}:27017/?authSource=admin"